+// Test that cluster info map is properly updated when a cluster is updated via CDS.
+TEST_F(UdpProxyFilterTest, ClusterDynamicInfoMapUpdate) {
+  InSequence s;
+
+  setup(readConfig(R"EOF(
+stat_prefix: foo
+matcher:
+  on_no_match:
+    action:
+      name: route
+      typed_config:
+        '@type': type.googleapis.com/envoy.extensions.filters.udp.udp_proxy.v3.Route
+        cluster: fake_cluster
+)EOF"));
+
+  // Verify that the cluster info was initialized in the constructor.
+  EXPECT_EQ(1, filter_->cluster_infos_.size());
+  auto initial_cluster_info = filter_->cluster_infos_["fake_cluster"].get();
+  EXPECT_NE(nullptr, initial_cluster_info);
+
+  // Simulate a cluster update by calling onClusterAddOrUpdate with the same cluster name
+  // but a new ThreadLocalCluster instance. This would happen during dynamic cluster updates.
+  // The old implementation would use emplace() which fails silently when the key already exists,
+  // leaving a stale pointer. The fixed implementation should use insert_or_assign() to replace it.
+  Upstream::ThreadLocalClusterCommand updated_cluster_command = [this]() -> Upstream::ThreadLocalCluster& {
+    return factory_context_.server_factory_context_.cluster_manager_.thread_local_cluster_;
+  };
+
+  filter_->onClusterAddOrUpdate("fake_cluster", updated_cluster_command);
+
+  // After the update, the map should still have exactly one entry for the cluster.
+  EXPECT_EQ(1, filter_->cluster_infos_.size());
+
+  // The cluster info should now point to the new/updated cluster, not the old one.
+  // With the buggy emplace() implementation, this would fail because the old entry would
+  // remain. With insert_or_assign(), the entry is replaced.
+  auto updated_cluster_info = filter_->cluster_infos_["fake_cluster"].get();
+  EXPECT_NE(nullptr, updated_cluster_info);
+
+  // Verify we can still process data with the updated cluster info.
+  expectSessionCreate(upstream_address_);
+  test_sessions_[0].expectWriteToUpstream("hello", 0, nullptr, true);
+  recvDataFromDownstream("10.0.0.1:1000", "10.0.0.2:80", "hello");
+}
