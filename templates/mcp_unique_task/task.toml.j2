version = "1.0"

[metadata]
name = "$task_id"
description = "$task_description"
license = "Apache-2.0"

[task]
id = "$task_id"
repo = "$primary_repo"
category = "$task_family"
language = "$language"
difficulty = "$difficulty"
time_limit_sec = $time_limit_sec
mcp_suite = "$mcp_suite"
use_case_id = $use_case_id
repo_set_id = "$repo_set_id"
mcp_unique = true
verification_modes = $verification_modes_json

[verification]
type = "test"
command = "bash /tests/test.sh"

reward_type = "score"
description = "$task_description"

[environment]
build_timeout_sec = 600.0
