FROM python:3.12-bookworm

WORKDIR /workspace

RUN apt-get update && apt-get install -y \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

RUN git clone --filter=blob:none --no-checkout https://github.com/django/django.git . && \
    git checkout 674eda1c03a3187905f48afee0f15226aa62fdf3 && \
    git config user.email "agent@example.com" && \
    git config user.name "Agent"

RUN pip install -e .
RUN rm -f tests/serializers/test_json.py 2>/dev/null || true

RUN mkdir -p /app /logs/verifier

# --- sg_only_env ---
RUN apt-get update && apt-get install -y --no-install-recommends rsync && rm -rf /var/lib/apt/lists/* || true
RUN cp -a /workspace /repo_full
RUN find /workspace -type f \( -name "*.py" -o -name "*.js" -o -name "*.ts" -o -name "*.go" -o -name "*.java" -o -name "*.c" -o -name "*.cpp" -o -name "*.h" -o -name "*.rs" -o -name "*.rb" -o -name "*.sh" -o -name "*.yaml" -o -name "*.yml" -o -name "*.toml" -o -name "*.json" -o -name "*.xml" -o -name "*.md" -o -name "*.rst" -o -name "*.txt" \) ! -path "*/.git/*" ! -path "*/site-packages/*" -exec truncate -s 0 {} \;
RUN touch /tmp/.sg_only_mode && echo '/workspace' > /tmp/.sg_only_workdir

ENTRYPOINT []
