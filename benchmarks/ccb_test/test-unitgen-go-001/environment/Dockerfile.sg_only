FROM golang:1.23-bookworm

WORKDIR /workspace

RUN apt-get update && apt-get install -y \
    git \
    python3 \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Clone Kubernetes at pinned commit
RUN git clone --filter=blob:none --no-checkout https://github.com/kubernetes/kubernetes.git . && \
    git checkout 8c9c67c000104450cfc5a5f48053a9a84b73cf93 && \
    git config user.email "agent@example.com" && \
    git config user.name "Agent"

# Remove existing test files
RUN rm -f staging/src/k8s.io/apimachinery/pkg/util/sets/*_test.go

# Download Go module dependencies
RUN cd staging/src/k8s.io/apimachinery && go mod download

RUN mkdir -p /app /logs/verifier

# --- sg_only_env: back up full repo, then truncate source ---
RUN apt-get update && apt-get install -y --no-install-recommends rsync && rm -rf /var/lib/apt/lists/* || true
RUN cp -a /workspace /repo_full
RUN find /workspace -type f \( -name "*.go" -o -name "*.py" -o -name "*.js" -o -name "*.ts" -o -name "*.java" -o -name "*.c" -o -name "*.cc" -o -name "*.cpp" -o -name "*.h" -o -name "*.rs" -o -name "*.rb" -o -name "*.cs" -o -name "*.swift" -o -name "*.sh" -o -name "*.lua" -o -name "*.proto" -o -name "*.yaml" -o -name "*.yml" -o -name "*.toml" -o -name "*.json" -o -name "*.xml" -o -name "*.md" -o -name "*.rst" -o -name "*.txt" \) ! -path "*/.git/*" ! -path "*/vendor/*" -exec truncate -s 0 {} \;
RUN touch /tmp/.sg_only_mode && echo '/workspace' > /tmp/.sg_only_workdir

ENTRYPOINT []
