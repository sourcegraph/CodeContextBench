FROM golang:1.23-bookworm

WORKDIR /workspace

RUN apt-get update && apt-get install -y \
    git \
    python3 \
    curl \
    libtagc0-dev \
    gcc \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

RUN git clone --filter=blob:none --no-checkout https://github.com/navidrome/navidrome.git . && \
    git checkout v0.9.3 && \
    git config user.email "agent@example.com" && \
    git config user.name "Agent"

ENV CGO_ENABLED=1
RUN go mod download

RUN mkdir -p /app /logs/verifier

# --- sg_only_env ---
RUN apt-get update && apt-get install -y --no-install-recommends rsync && rm -rf /var/lib/apt/lists/* || true
RUN cp -a /workspace /repo_full
RUN find /workspace -type f \( -name "*.go" -o -name "*.py" -o -name "*.js" -o -name "*.ts" -o -name "*.java" -o -name "*.c" -o -name "*.cpp" -o -name "*.h" -o -name "*.rs" -o -name "*.proto" -o -name "*.yaml" -o -name "*.yml" -o -name "*.toml" -o -name "*.json" -o -name "*.xml" -o -name "*.md" -o -name "*.txt" -o -name "*.sh" \) ! -path "*/.git/*" ! -path "*/vendor/*" -exec truncate -s 0 {} \;
RUN touch /tmp/.sg_only_mode && echo '/workspace' > /tmp/.sg_only_workdir

ENTRYPOINT []
