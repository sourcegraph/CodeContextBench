# Largerepo Task Environment — sg_only_env variant
# Source: microsoft/vscode (1.96.0)
#
# Same toolchain as the standard Dockerfile but source files are truncated
# so the agent must use Sourcegraph MCP for all code access.
# The verifier wrapper restores the full repo before running tests.

FROM node:22-bookworm

WORKDIR /workspace

# Install dependencies
RUN apt-get update && apt-get install -y \
    git \
    curl \
    build-essential \
    python3 \
    python3-pip \
    rsync \
    && rm -rf /var/lib/apt/lists/*

# Install Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# Clone the VS Code repository at pinned commit (1.96.0)
RUN git clone --filter=blob:none --no-checkout https://github.com/microsoft/vscode.git . && \
    git checkout 138f619c86f1199955d53b4166bef66ef252935c && \
    git config user.email "agent@example.com" && \
    git config user.name "Agent"

# Install VS Code dependencies (required for testing)
RUN npm install --legacy-peer-deps 2>&1 | tail -10 || true

# --- sg_only_env: back up full repo, then truncate source ---
RUN cp -a /workspace /repo_full

RUN find /workspace -type f \( \
    -name "*.ts" -o -name "*.js" -o -name "*.tsx" -o -name "*.jsx" \
    -o -name "*.py" -o -name "*.go" -o -name "*.java" \
    -o -name "*.c" -o -name "*.cpp" -o -name "*.h" \
    -o -name "*.rs" -o -name "*.rb" -o -name "*.cs" \
    -o -name "*.kt" -o -name "*.swift" -o -name "*.vue" -o -name "*.scala" \
    \) ! -path "*/.git/*" ! -path "*/node_modules/*" -exec truncate -s 0 {} \;

RUN touch /tmp/.sg_only_mode && echo '/workspace' > /tmp/.sg_only_workdir
