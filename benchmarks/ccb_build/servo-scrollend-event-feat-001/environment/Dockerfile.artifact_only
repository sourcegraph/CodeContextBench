# servo-scrollend-event-feat-001 — artifact_only variant (build-requiring)
# Repos cloned for baseline agent to read locally.
# MCP agent deletes source files at runtime via agent startup script.
# Verifier applies patches from review.json to /repo_full copy for scoring.

FROM rust:1.83-bookworm

WORKDIR /workspace

# Install dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    python3 \
    python3-pip \
    build-essential \
    autoconf \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

# Create claude user and writable work dirs before clone.
RUN (adduser --disabled-password --gecos '' claude 2>/dev/null || true) && \
    mkdir -p /workspace /logs && \
    chown -R claude:claude /workspace /logs

# Clone the actual Servo repository at pinned commit
# This ensures BOTH baseline and MCP agents have identical file access
# Note: Servo is a large Rust codebase (~1.6GB)
USER claude
RUN git clone --filter=blob:none --no-checkout https://github.com/servo/servo.git . && \
    git checkout be6a2f99a1e80060228f41280fd7d2178983e7ed && \
    git config user.email "agent@example.com" && \
    git config user.name "Agent"
USER root

# Task setup complete
# Note: Both baseline and MCP agents now have access to the real Servo source.
# Baseline will use local grep/find/rg. MCP will use Sourcegraph semantic search.
# --- artifact_only: backup full repo for verifier scoring ---
# Source stays in /workspace (readable by baseline agent).
# MCP agent deletes source files at runtime via agent startup script.
RUN cp -a /workspace /repo_full
RUN chmod 700 /repo_full
RUN touch /tmp/.artifact_only_mode && echo '/workspace' > /tmp/.artifact_only_workdir

ENTRYPOINT []
