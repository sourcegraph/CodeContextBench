{
  "id": "CCX-platform-100",
  "family": "platform-deprecated-api-inventory",
  "use_case_id": 100,
  "category": "A",
  "mcp_suite": "ccb_mcp_platform",
  "prd": {
    "user_story": "As a platform engineer, I need to inventory all deprecated API fields still defined in Kubernetes to plan deprecation removal timelines and assess backward compatibility impact.",
    "constraints": [
      "Search staging/src/k8s.io/api/ and pkg/apis/ directories.",
      "Include both API types (staging) and internal types (pkg/apis).",
      "Include the annotation constants file with deprecated annotation key constants.",
      "Only include files that DEFINE deprecated identifiers, not files that merely reference them.",
      "Write your findings to /workspace/answer.json."
    ],
    "success_definition": "Agent finds all 8 files that define deprecated struct fields or constants in kubernetes/kubernetes.",
    "seed_prompt": "Find all Go source files in kubernetes/kubernetes that define struct fields or constants with Deprecated in the identifier name."
  },
  "artifacts": {
    "repo_set_id": "multi-org-go",
    "oracle": {
      "required_files": [
        {"repo": "kubernetes/kubernetes", "path": "staging/src/k8s.io/api/core/v1/types.go"},
        {"repo": "kubernetes/kubernetes", "path": "staging/src/k8s.io/apiserver/pkg/apis/example/v1/types.go"},
        {"repo": "kubernetes/kubernetes", "path": "staging/src/k8s.io/apimachinery/pkg/apis/testapigroup/v1/types.go"},
        {"repo": "kubernetes/kubernetes", "path": "staging/src/k8s.io/api/discovery/v1/types.go"},
        {"repo": "kubernetes/kubernetes", "path": "pkg/apis/discovery/types.go"},
        {"repo": "kubernetes/kubernetes", "path": "staging/src/k8s.io/api/events/v1/types.go"},
        {"repo": "kubernetes/kubernetes", "path": "staging/src/k8s.io/api/events/v1beta1/types.go"},
        {"repo": "kubernetes/kubernetes", "path": "pkg/apis/core/annotation_key_constants.go"}
      ],
      "required_symbols": [],
      "required_references": [],
      "dependency_chains": []
    }
  },
  "evaluation": {
    "modes": ["deterministic"],
    "checks": [
      {
        "type": "file_set_match",
        "params": {}
      },
      {
        "type": "keyword_presence",
        "params": {
          "required_keywords": ["DeprecatedServiceAccount", "DeprecatedTopology", "DeprecatedSource", "DeprecatedSeccompProfileDockerDefault"]
        }
      }
    ],
    "eval_script": "/tests/eval.sh",
    "pass_exit_code": 0
  },
  "logging": {
    "required_metrics": ["oracle_coverage", "time_to_first_oracle_hit_ms", "unique_repos_touched"]
  }
}
